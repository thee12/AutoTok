# AutoTok local configuration.
# Copy to .env for local use. Do not commit real secrets.

AUTOTOK_ENV=local
AUTOTOK_LOG_LEVEL=INFO
AUTOTOK_LOG_FORMAT=text
AUTOTOK_DATA_DIR=data
AUTOTOK_TTS_PROVIDER=local_wav
AUTOTOK_TTS_TIMEOUT_SECONDS=30
# Optional for live Reddit Data API source discovery. Do not commit real tokens.
AUTOTOK_REDDIT_OAUTH_TOKEN=
AUTOTOK_REDDIT_USER_AGENT=AutoTok/0.1 local-source-ingestion
AUTOTOK_REDDIT_TIMEOUT_SECONDS=20

# Optional for Phase 11 TikTok Content Posting API integration. Do not commit real secrets.
AUTOTOK_TIKTOK_CLIENT_KEY=
AUTOTOK_TIKTOK_CLIENT_SECRET=
AUTOTOK_TIKTOK_ACCESS_TOKEN=
AUTOTOK_TIKTOK_REFRESH_TOKEN=
AUTOTOK_TIKTOK_TIMEOUT_SECONDS=30
